# 5. Deformation Settings (Z-axis)
variable        tmp equal "lz"
variable        L0 equal ${tmp}
variable        L0 equal 119.678800758201
print           "Initial box length (L0) = ${L0}"
Initial box length (L0) = 119.678800758201

# Calculate strain and stress in Z
variable        strain equal "(lz - v_L0)/v_L0"
variable        sxx equal "-pxx/10000"
variable        syy equal "-pyy/10000"
variable        szz equal "-pzz/10000" # 1 MPa = 10 bars

fix             SS_out all print 200 "${strain} ${sxx} ${syy} ${szz}" file stress_strain.dat screen no title "# Strain Stress_xx(GPa) Stress_yy(GPa) Stress_zz(GPa)"

# 6. Tensile/Compression Run
thermo          100
thermo_style    custom step lx ly lz press pxx pyy pzz ke pe temp v_strain v_szz

# NPT ensemble allowing X and Y to relax (Poisson effect) while Z is deformed
#fix             1 all npt temp 300 300 1 x 0 0 1 y 0 0 1 drag 1
fix             1 all nvt temp 100.0 100.0 0.1


# Prevent the nanopillar from drifting in X/Y and rotating
#fix             stop_drift all momentum 100 linear 1 1 0 angular

# Set strain rate (positive for tension, negative for compression)
variable        srate equal -1.0e8
variable        srate1 equal "v_srate / 1.0e12"
fix             2 all deform 1 z erate ${srate1} units box remap x
fix             2 all deform 1 z erate -0.0001 units box remap x

dump            1 all custom 600 AlCu_deform.dump id type x y z

run             400000
